# =============================================================================
# DJ Star Original Movies - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control.
# =============================================================================

# --- Application Configuration ---
NODE_ENV=development
APP_NAME=DJ Star Original Movies
APP_URL=http://localhost:5000
PORT=5000

# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dj_star_movies
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

# --- JWT Configuration ---
JWT_SECRET=change_this_to_a_very_long_random_secret_key
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=DJStarOriginalMovies

# --- Email Configuration (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@djstarmovies.com
EMAIL_FROM_NAME="DJ Star Original Movies"

# --- Cloudflare R2 Configuration ---
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=dj-star-movies
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
R2_REGION=auto

# --- M-Pesa Buy Goods (Till Number) Configuration ---
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=your_till_number
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa-callback
MPESA_TIMEOUT_URL=https://yourdomain.com/api/payments/mpesa-timeout

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=5

# --- File Upload ---
MAX_FILE_SIZE=5242880000
UPLOAD_TEMP_DIR=./temp

# --- Streaming ---
STREAM_CHUNK_SIZE=8388608

# --- Security ---
BCRYPT_SALT_ROUNDS=12
VERIFICATION_CODE_EXPIRY_MINUTES=15
PASSWORD_RESET_EXPIRY_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# --- Developer Commission ---
DEVELOPER_COMMISSION_PERCENTAGE=40

# --- Logging ---
LOG_LEVEL=debug
LOG_DIR=./logs

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Scheduled Jobs ---
CLEANUP_SCHEDULE=0 */6 * * *
