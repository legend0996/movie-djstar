{
  "name": "dj-star-original-movies-backend",
  "version": "2.0.0",
  "description": "Production-ready backend for DJ Star Original Movies platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:deploy": "npx prisma migrate deploy",
    "prisma:seed": "node database/prisma/seed.js",
    "prisma:studio": "npx prisma studio",
    "migrate": "node database/migrate.js",
    "seed": "node database/seed.js",
    "setup": "npm install && npx prisma generate && npx prisma migrate deploy && node database/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.0",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0"
  },
  "prisma": {
    "schema": "../database/prisma/schema.prisma",
    "seed": "node ../database/prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
