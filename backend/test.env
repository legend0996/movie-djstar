NODE_ENV=test
APP_NAME=DJ Star Original Movies
APP_URL=http://localhost:5000
PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=dj_star_movies_test
DB_USER=root
DB_PASSWORD=

JWT_SECRET=test-jwt-secret-key-for-testing-only-1234567890
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=DJStarOriginalMovies

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@djstarmovies.com
EMAIL_FROM_NAME="DJ Star Original Movies"

R2_ENDPOINT=https://account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=test-key
R2_SECRET_ACCESS_KEY=test-secret
R2_BUCKET_NAME=dj-star-movies
R2_PUBLIC_URL=https://pub-hash.r2.dev
R2_REGION=auto

MPESA_CONSUMER_KEY=test-consumer-key
MPESA_CONSUMER_SECRET=test-consumer-secret
MPESA_PASSKEY=test-passkey
MPESA_SHORTCODE=123456
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=http://localhost:5000/api/payments/mpesa-callback
MPESA_TIMEOUT_URL=http://localhost:5000/api/payments/mpesa-timeout

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=5

MAX_FILE_SIZE=5242880000
UPLOAD_TEMP_DIR=./temp
STREAM_CHUNK_SIZE=8388608

BCRYPT_SALT_ROUNDS=12
VERIFICATION_CODE_EXPIRY_MINUTES=15
PASSWORD_RESET_EXPIRY_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

DEVELOPER_COMMISSION_PERCENTAGE=40

LOG_LEVEL=error
LOG_DIR=./logs

CORS_ORIGIN=http://localhost:3002
CLEANUP_SCHEDULE=0 */6 * * *

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=false
